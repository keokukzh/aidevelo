{
  "version": 2,
  "buildCommand": "pnpm -r build",
  "installCommand": "pnpm install --prod=false",
  "framework": null,
  "functions": {
    "server/src/vercel-entry.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/src/vercel-entry.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
