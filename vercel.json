{
  "version": 2,
  "buildCommand": "cd ui && npm exec -- vite build",
  "installCommand": "npm exec -- pnpm@9.15.4 install",
  "outputDirectory": "ui/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.aidevelo.ai/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
