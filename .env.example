# Copy to `.env` and edit. Do not commit real secrets.
#
# Local dev (see doc/DEVELOPING.md): `pnpm dev`
#   Leave DATABASE_URL unset to use embedded PGlite.
#
# Docker full stack: `docker compose up -d db server` (docker-compose.yml)
#   The server service sets DATABASE_URL to Postgres on the `db` host — do not point DATABASE_URL
#   at localhost unless you run Postgres inside the same container.
#   BETTER_AUTH_SECRET is required for compose (or export it in the shell before `docker compose`).
#
# Docker quickstart: `docker compose -f docker-compose.quickstart.yml up -d --build`
#   If your `.env` sets DATABASE_URL=...@localhost, the container will try Postgres on itself and fail.
#   For quickstart, omit DATABASE_URL here or only use a compose file that overrides it.

# BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# Optional local Postgres when not using PGlite:
# DATABASE_URL=postgres://aidevelo:aidevelo@localhost:5432/aidevelo

# PORT=3100
# SERVE_UI=false

# Required for Docker Compose (generate a random string at least 32 chars, e.g. `openssl rand -base64 32`):
# BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Agent JWT secret for AIDEVELO_API_KEY injection into local agent runs (required for agents to call the API):
# AIDEVELO_AGENT_JWT_SECRET=replace-with-a-random-secret-at-least-32-chars

# Optional provider keys (also used by Docker Compose interpolation):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# MiniMax (Claude Code token plan / managed_service; see doc/DOCKER.md):
# MINIMAX_API_KEY=
# Default international Anthropic-compatible base; use https://api.minimaxi.com/anthropic in China.
# MINIMAX_ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# AIDEVELO_MINIMAX_DELEGATE=codex
# AIDEVELO_SKIP_MINIMAX_CLAUDE=true
